# ==============================================================================
# AgentReplay — root env template (Supabase project credentials)
# ==============================================================================
# Copy to `.env` and fill in real values from the Supabase dashboard
# (Project Settings -> Database / API). Never commit `.env`.

# --- Postgres ---
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Password must be percent-encoded in connection strings (@ -> %40, etc.)
SUPABASE_DB_URL=postgresql://postgres:<urlencoded-password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL_ASYNCPG=postgresql+asyncpg://postgres:<urlencoded-password>@db.<project-ref>.supabase.co:5432/postgres

# --- Supabase platform API/keys — NOT used by ingest/ today. FastAPI is our
# API layer (CLAUDE.md architecture); Supabase here = managed Postgres only.
# Stored for future optionality (Day 2+ viewer auth, storage, edge functions). ---
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_REST_URL=https://<project-ref>.supabase.co/rest/v1/
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SIGNING_KEY=
SUPABASE_JWT_SIGNING_KEY_PREV=

# ==============================================================================
# examples/resume_bot.py demo (Day 1 / chunk 1.6 checkpoint)
# ==============================================================================
# NVIDIA NIM (OpenAI-compatible, free endpoint) — get a key from
# build.nvidia.com -> any model -> API Keys. Temporary stand-in for
# ANTHROPIC_API_KEY until that's wired up (see PROGRESS.md "Blockers").
NVIDIA_API_KEY=nvapi-...

# agentreplay.init() credentials for the "resume-bot" project
# (create via `python ingest/scripts/create_project.py "Resume Bot" resume-bot`).
AGENTREPLAY_API_KEY=ar_...
AGENTREPLAY_PROJECT_ID=resume-bot
AGENTREPLAY_ENDPOINT=http://localhost:8000
