
AGENTREPLAY_INGEST_DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<urlencoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
AGENTREPLAY_INGEST_ENVIRONMENT=development

AGENTREPLAY_INGEST_CORS_ORIGINS=http://localhost:3000

# Chunk 3.6 — Celery + Sonnet/MAST classifier (CLAUDE.md §3.6). Run a worker
# with `celery -A app.celery_app worker --loglevel=info` (from `ingest/`).
AGENTREPLAY_INGEST_REDIS_URL=redis://localhost:6379/0

# "sonnet" (default) or "nim" (CLAUDE.md §5 NIM cost-cutting track, scoped to
# the classifier only — same NVIDIA NIM free-tier swap used by
# examples/resume_bot.py when no ANTHROPIC_API_KEY is available).
AGENTREPLAY_INGEST_CLASSIFIER_BACKEND=sonnet
AGENTREPLAY_INGEST_ANTHROPIC_API_KEY=
AGENTREPLAY_INGEST_ANTHROPIC_MODEL=claude-sonnet-4-6
AGENTREPLAY_INGEST_NIM_API_KEY=
AGENTREPLAY_INGEST_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
AGENTREPLAY_INGEST_NIM_MODEL=meta/llama-3.1-70b-instruct
